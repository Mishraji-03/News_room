# ============================================
# AutoNews AI - Environment Variables
# Copy this to .env and fill in your API keys
# ============================================

# YouTube / Google (get from console.cloud.google.com)
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# NewsAPI.org (get from newsapi.org — free: 100 req/day)
NEWS_API_KEY=

# Google Gemini (get from aistudio.google.com — free: 1500 req/day)
GEMINI_API_KEY=

# Instagram / Meta (get from developers.facebook.com)
META_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
