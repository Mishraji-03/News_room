# ============================================================
# AutoNews AI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ====================== AI ======================
GEMINI_API_KEY=your_gemini_api_key_here

# ====================== NEWS SOURCES ======================
NEWS_API_KEY=your_newsapi_org_key_here        # https://newsapi.org (100 req/day free)
# GNEWS_API_KEY=your_gnews_key_here           # optional

# ====================== YOUTUBE ======================
YOUTUBE_CLIENT_ID=your_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret
# YOUTUBE_API_KEY=your_yt_data_api_key        # optional, read-only ops

# ====================== INSTAGRAM ======================
META_ACCESS_TOKEN=your_meta_graph_api_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# ====================== CHANNEL ======================
CHANNEL_NAME=AutoNewsAI
CHANNEL_HANDLE=@AutoNewsAI
LANGUAGE=hinglish                             # hindi | english | hinglish
NICHE=Tech & AI News

# ====================== PIPELINE ======================
VIDEOS_PER_DAY=4
MAX_VIDEOS_PER_RUN=1
SCHEDULE_SLOTS=06:00,12:00,17:00,19:00

# ====================== VIDEO ======================
TTS_VOICE=hi-IN-SwaraNeural
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
